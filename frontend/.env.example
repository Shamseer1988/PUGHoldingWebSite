# ============================================================
# Paris United Group Holding - Frontend Environment (.env.example)
# Copy to .env.local and adjust for your environment.
# ============================================================

# Base URL of the FastAPI backend (server-side calls)
API_BASE_URL=http://localhost:8000/api/v1

# Public base URL of the backend (exposed to the browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Public site URL used for canonical links / metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public site name (used in metadata)
NEXT_PUBLIC_SITE_NAME=Paris United Group Holding

# Phase A-7 — CDN base URL for media uploads served by Cloudflare
# R2. When set, ``normaliseMediaUrl`` rewrites legacy
# ``/api/v1/uploads/...`` paths to ``${this}/<key>`` so the browser
# fetches from the CDN. Leave empty to keep the existing API-host
# resolution.
NEXT_PUBLIC_MEDIA_BASE_URL=

# Phase A-8 — Sentry error tracking. Public DSN ships in the
# browser bundle. Leave empty to skip Sentry entirely (dev / CI).
NEXT_PUBLIC_SENTRY_DSN=

# Release identifier sent on every event. Set to the git short SHA
# or the build's semver tag so the Sentry dashboard can group
# regressions by release. Empty in dev is fine.
NEXT_PUBLIC_APP_VERSION=

# Sentry CI fields — only needed when you re-enable source-map
# upload via ``sourcemaps.disable: false`` in next.config.mjs.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
