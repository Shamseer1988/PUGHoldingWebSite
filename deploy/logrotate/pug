# Paris United Group Holding — log rotation for the custom /var/log/pug/
# directory. Drop this file at /etc/logrotate.d/pug.
#
# (Nginx + PostgreSQL logs are rotated by their own packages; this only
# covers application-specific logs such as the daily pg_backup output.)

/var/log/pug/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 pug pug
    sharedscripts
}
