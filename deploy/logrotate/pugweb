# Paris United Group — log rotation for the /var/log/pugweb/
# directory. Drop this file at /etc/logrotate.d/pugweb.
#
# Nginx + PostgreSQL logs are rotated by their own packages; this
# only covers application-specific logs such as the daily pg_backup
# output.

/var/log/pugweb/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 parisgroup parisgroup
    sharedscripts
}
