# ============================================================
# Paris United Group Holding - Backend Environment (.env.example)
# Copy this file to .env and replace the placeholder values.
# ============================================================

# --- Application ---
APP_NAME=PUG Holding API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Security ---
# IMPORTANT: change in production. Use: openssl rand -hex 32
SECRET_KEY=change-me-to-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# --- Database (PostgreSQL) ---
POSTGRES_USER=pug_user
POSTGRES_PASSWORD=pug_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pug_holding
# Optional override: full DATABASE_URL takes precedence if set
# DATABASE_URL=postgresql+psycopg2://pug_user:pug_password@localhost:5432/pug_holding

# --- CORS ---
# Comma-separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- File uploads ---
UPLOAD_DIR=app/uploads
MAX_UPLOAD_SIZE_MB=20

# --- Azure OpenAI (placeholders for Phase 13 / 17) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AI_ENABLED=false

# --- Email (placeholders for later phases) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
