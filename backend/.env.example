# ============================================================
# Paris United Group Holding - Backend Environment (.env.example)
# Copy this file to .env and replace the placeholder values.
# ============================================================

# --- Application ---
APP_NAME=PUG Holding API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Security ---
# IMPORTANT: change in production. Use: openssl rand -hex 32
SECRET_KEY=change-me-to-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# --- Database (PostgreSQL) ---
POSTGRES_USER=pug_user
POSTGRES_PASSWORD=pug_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pug_holding
# Optional override: full DATABASE_URL takes precedence if set
# DATABASE_URL=postgresql+psycopg2://pug_user:pug_password@localhost:5432/pug_holding

# --- CORS ---
# Comma-separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- File uploads ---
UPLOAD_DIR=app/uploads
MAX_UPLOAD_SIZE_MB=20

# --- Azure OpenAI (placeholders for Phase 13 / 17) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AI_ENABLED=false

# --- Email (placeholders for later phases) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# --- Phase A-3: Sentry + Redis (placeholders, wired later) ---
# Sentry DSN — when set, ``create_app`` initialises sentry-sdk
# with traces_sample_rate=0.1 and ``send_default_pii=False``.
# Leave empty to skip Sentry entirely (dev / CI).
SENTRY_DSN=
# Redis URL — used by Phase B-2 (rate limit + cache) and B-3 (ARQ
# background queue). The default points at a local instance so
# docker-compose development just works.
REDIS_URL=redis://localhost:6379/0

# --- Phase A-6: Cloudflare R2 object storage ---
# When all four required values are set, ``app.services.storage``
# uses the R2 backend instead of writing to disk. Leave any of
# these empty to keep the local-disk fallback active.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pug-holding-media
# Optional custom domain (Phase A-5 step 4); falls back to the
# long ``<account>.r2.cloudflarestorage.com/<bucket>`` form when
# unset.
R2_PUBLIC_BASE_URL=
